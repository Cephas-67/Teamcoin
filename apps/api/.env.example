# ─── Supabase (Settings → API) ────────────────────────────────────────────
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ─── JWT (générer une longue chaîne random, p.ex. via openssl rand -hex 32) ─
JWT_SECRET=changeme-genere-une-vraie-clef-de-64-caracteres
JWT_EXPIRES_IN=30d

# ─── Resend (envoi des OTP par email) ─────────────────────────────────────
# Crée un compte gratuit sur https://resend.com puis copie ta clé ici.
# Sans domaine vérifié, MAIL_FROM doit rester onboarding@resend.dev
# et tu ne pourras envoyer qu'à l'email de ton compte Resend.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
MAIL_FROM=KandoFoncier <onboarding@resend.dev>

# ─── Divers ───────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
